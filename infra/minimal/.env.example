APP_ENV=production
LOG_LEVEL=info
ENABLE_DEBUG_TOOLS=false
ALLOW_DEV_AUTH=false
DOMAIN=localhost

POSTGRES_DB=bloodsugar
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-long-random
DATABASE_URL=postgresql+psycopg://app:change-me-long-random@db:5432/bloodsugar

BACKEND_CORS_ORIGINS=https://localhost,http://localhost
MAX_REQUEST_BODY_BYTES=1048576
# Configure either AUTH_JWT_SECRET for minimal HS256 bootstrap or AUTH_JWKS_URL
# for provider-issued RS256 access tokens. Production requires issuer, audience,
# and jti enforcement for either path.
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=bloodsugar-api
AUTH_JWKS_URL=
AUTH_JWKS_TIMEOUT_SECONDS=5
AUTH_JWT_REQUIRE_JTI=true
AUTH_OIDC_JWKS_URL=https://auth.example.com/.well-known/jwks.json
AUTH_OIDC_ISSUER=https://auth.example.com
AUTH_OIDC_AUDIENCE=bloodsugar-mobile
AUTH_OIDC_TIMEOUT_SECONDS=5
AUTH_OIDC_MAX_AGE_SECONDS=3600
AUTH_LOGIN_CLIENT_RATE_LIMIT_COUNT=30
AUTH_LOGIN_CLIENT_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGOUT_CLIENT_RATE_LIMIT_COUNT=120
AUTH_LOGOUT_CLIENT_RATE_LIMIT_WINDOW_SECONDS=60
VITE_API_BASE_URL=/api
VITE_ENABLE_DEBUG_TOOLS=false
VITE_VOICE_PLAN=trial
VITE_TRIAL_DAILY_VOICE_SECONDS=300
VITE_PAID_DAILY_VOICE_SECONDS=600
VITE_SINGLE_RECORDING_LIMIT_SECONDS=60
VITE_VOICE_QUOTA_WARNING_SECONDS=120
VITE_SILENT_AUDIO_MIN_BYTES=1024

REDIS_URL=redis://redis:6379/0

LOCAL_LLM_PARSER_URL=http://ollama:11434/v1/chat/completions
OLLAMA_CHAT_URL=http://ollama:11434/api/chat
LOCAL_LLM_KEEP_ALIVE=10m
LOCAL_LLM_MAX_TOKENS=900
LOCAL_LLM_TIMEOUT_SECONDS=45
LOCAL_LLM_REPAIR_FALLBACK_ENABLED=true
OLLAMA_QWEN25_MODEL_ID=qwen2.5:1.5b
OLLAMA_GEMMA3_MODEL_ID=gemma3:1b
OLLAMA_LLAMA32_MODEL_ID=llama3.2:1b

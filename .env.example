APP_ENV=local
LOG_LEVEL=debug
ENABLE_DEBUG_TOOLS=false
ALLOW_DEV_AUTH=true

POSTGRES_DB=bloodsugar
POSTGRES_USER=app
POSTGRES_PASSWORD=app
DATABASE_URL=postgresql+psycopg://app:app@db:5432/bloodsugar

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_REQUEST_BODY_BYTES=1048576
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWKS_URL=
AUTH_JWKS_TIMEOUT_SECONDS=5
AUTH_JWT_REQUIRE_JTI=false
AUTH_OIDC_JWKS_URL=
AUTH_OIDC_ISSUER=
AUTH_OIDC_AUDIENCE=
AUTH_OIDC_TIMEOUT_SECONDS=5
AUTH_OIDC_MAX_AGE_SECONDS=3600
AUTH_LOGIN_CLIENT_RATE_LIMIT_COUNT=30
AUTH_LOGIN_CLIENT_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGOUT_CLIENT_RATE_LIMIT_COUNT=120
AUTH_LOGOUT_CLIENT_RATE_LIMIT_WINDOW_SECONDS=60
VITE_API_BASE_URL=http://localhost:8000
VITE_ENABLE_DEBUG_TOOLS=false
EXPO_PUBLIC_ENABLE_DEBUG_TOOLS=false
VITE_VOICE_PLAN=trial
VITE_TRIAL_DAILY_VOICE_SECONDS=300
VITE_PAID_DAILY_VOICE_SECONDS=600
VITE_SINGLE_RECORDING_LIMIT_SECONDS=60
VITE_VOICE_QUOTA_WARNING_SECONDS=120
VITE_SILENT_AUDIO_MIN_BYTES=1024

# Optional local Gemma parser endpoint.
# Expected protocol: OpenAI-compatible chat completions endpoint.
# Example for a host-side local server:
# GEMMA4_PARSER_URL=http://host.docker.internal:11434/v1/chat/completions
GEMMA4_PARSER_URL=
GEMMA4_MODEL_ID=gemma-4-e2b-local-pending
GEMMA4_TIMEOUT_SECONDS=60

# Optional DeepSeek endpoint.
# Required protocol: OpenAI-compatible chat completions endpoint.
# Example for cloud API endpoint:
# DEEPSEEK_PARSER_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_API_KEY=sk-...
DEEPSEEK_PARSER_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_ID=deepseek-chat
DEEPSEEK_SYSTEM_PROMPT=你是中文健康記錄轉錄解析器（只做結構化抽取，不做醫療建議或判斷）。你僅能根據 transcript 內容抽取 compact IR 欄位：records、rejected、needs_confirmation；不得編造任何欄位。請只輸出精簡、合法、可直接 parse 的 JSON：1) records: 每筆紀錄需具備 schema 規定欄位；2) rejected: 無法確認或可能有歧義的內容；3) needs_confirmation 必須為 true。
DEEPSEEK_ANALYSIS_ADDENDUM=分析規則：1. 先判斷可驗證性，能對應到 transcript 的片段才進入 records；無法確認者放入 rejected。2. 只保留逐字明確、可追溯的數值/時間/單位；缺值或可疑內容一律拒絕。3. 不輸出醫療建議、不輸出 raw transcript、不輸出額外說明文字，只回傳最小 schema JSON。

# Docker Compose Ollama local parser defaults.
LOCAL_LLM_PARSER_URL=http://ollama:11434/v1/chat/completions
OLLAMA_CHAT_URL=http://ollama:11434/api/chat
LOCAL_LLM_KEEP_ALIVE=30m
LOCAL_LLM_MAX_TOKENS=960
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_REPAIR_FALLBACK_ENABLED=false
OLLAMA_QWEN25_MODEL_ID=qwen2.5:1.5b
OLLAMA_GEMMA3_MODEL_ID=gemma3:1b
OLLAMA_LLAMA32_MODEL_ID=llama3.2:1b
OLLAMA_KEEP_ALIVE=30m
